{
  "name": "ai-kanban-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "setup:tailscale": "node scripts/update-tailscale.js",
    "start": "npm run setup:tailscale && expo start",
    "android": "npm run setup:tailscale && expo start --android",
    "ios": "npm run setup:tailscale && expo start --ios",
    "ios:phone": "npm run setup:tailscale && expo run:ios",
